# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# ============================================================================
# AUTHENTICATION
# ============================================================================

# Next Auth Secret - Generate with: npx auth secret
# https://next-auth.js.org/configuration/options#secret
AUTH_SECRET=""

# Next Auth Discord Provider
# https://discord.com/developers/applications
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Next Auth Google OAuth
# https://console.cloud.google.com/
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ============================================================================
# DATABASE
# ============================================================================

# Prisma - PostgreSQL Connection String
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL="postgresql://postgres:password@localhost:5432/smart-shelf"

# ============================================================================
# EMAIL SERVICE (RESEND)
# ============================================================================

# Resend API Key - Get from https://resend.com/api-keys
RESEND_API_KEY=""

# Email address to send alerts from
RESEND_FROM_EMAIL="alerts@smart-shelf.app"

# ============================================================================
# CRON JOBS
# ============================================================================

# Secret token for Vercel Cron authentication
# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=""

# ============================================================================
# ERROR TRACKING (SENTRY)
# ============================================================================

# Sentry DSN for error tracking - Get from https://sentry.io/
# Optional: If not set, error tracking will be disabled
SENTRY_DSN=""

# Sentry Auth Token for Vercel integration setup
SENTRY_AUTH_TOKEN=""

# ============================================================================
# NEXT.JS
# ============================================================================

# Application URL for auth callbacks
NEXTAUTH_URL="http://localhost:3000"

# Node environment
NODE_ENV="development"
